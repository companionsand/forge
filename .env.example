# =============================================================================
# Kin AI Raspberry Pi Client Wrapper - Environment Configuration
# =============================================================================
#
# This file contains configuration for the wrapper installation and launch scripts.
# Copy this file to .env and fill in your values.
#
# IMPORTANT: This .env is for the WRAPPER, not the client.
# The client has its own .env file created during installation.
#
# =============================================================================

# =============================================================================
# RELEASE CONFIGURATION
# =============================================================================

# GitHub repository that hosts the obfuscated release assets
# Default: companionsand/raspberry-pi-client
CLIENT_RELEASE_REPO=companionsand/raspberry-pi-client

# Release channel to install when CLIENT_RELEASE_TAG is not pinned
# Options: production, staging
CLIENT_RELEASE_CHANNEL=production

# Optional explicit release tag to pin a device to a specific release
# Example: CLIENT_RELEASE_TAG=v0.1.0
# CLIENT_RELEASE_TAG=

# Asset platform suffix used by the wrapper
# Default: linux-aarch64
CLIENT_RELEASE_PLATFORM=linux-aarch64

# Optional GitHub token for downloading private release assets
# Leave unset when release assets are public
# CLIENT_RELEASE_GITHUB_TOKEN=

# =============================================================================
# DEVICE PROVISIONING (REQUIRED FOR AUTOMATED SETUP)
# =============================================================================
#
# These variables are used during automated installation from the admin portal.
# When you download an installer package from the portal, these are pre-filled.
#
# If installing manually, you must set these values:

# Unique device identifier (UUID format)
# DEVICE_ID=your-device-uuid-here

# Ed25519 private key for device authentication (base64-encoded)
# DEVICE_PRIVATE_KEY=your-base64-encoded-private-key-here

# 4-character uppercase alphanumeric BLE discriminator shown as Olympia_XXXX
# BLE_DISCRIMINATOR=A7K3

# OpenTelemetry central collector endpoint (for observability)
# Example: https://your-otel-collector.com:4318
# OTEL_CENTRAL_COLLECTOR_ENDPOINT=https://otel-collector.onrender.com:4318

# Deployment environment
# Options: production, staging, development
# ENV=production

# =============================================================================
# NOTES
# =============================================================================
#
# Installation Methods:
# ---------------------
#
# Method 1: Admin Portal (Recommended)
# 1. Go to admin portal and create a new device
# 2. Download the installer package (includes pre-filled .env)
# 3. Extract on Raspberry Pi: tar -xzf kin-installer.tar.gz
# 4. Run: sudo ./install.sh
# 5. Everything is configured automatically!
#
# Method 2: Manual Installation
# 1. Clone this repository
# 2. Copy .env.example to .env
# 3. Fill in DEVICE_ID, DEVICE_PRIVATE_KEY, OTEL_CENTRAL_COLLECTOR_ENDPOINT, ENV
# 4. Run: sudo ./install.sh
# 5. The client .env will be created automatically with minimal config
#
# Release Channels:
# -----------------
# The wrapper downloads versioned release artifacts instead of cloning source.
# - Use CLIENT_RELEASE_CHANNEL=production for the latest stable release
# - Use CLIENT_RELEASE_CHANNEL=staging for the latest prerelease
# - Set CLIENT_RELEASE_TAG to pin a device to one exact release
# - Changes apply on next restart (launch.sh checks GitHub Releases)
#
# Audio Setup:
# ------------
# This wrapper assumes you're using a ReSpeaker 4-Mic Array with hardware
# acoustic echo cancellation (AEC). Audio devices are auto-detected via ALSA.
#
# Wrapper vs Client .env:
# -----------------------
# - This .env (wrapper): Controls installation and launcher behavior
# - Client .env: Contains device credentials and runtime config
# - The wrapper creates the client .env during installation
# - You typically only need to edit the wrapper .env
#
# =============================================================================
